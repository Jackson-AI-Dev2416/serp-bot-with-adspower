# Local runtime data (settings, API keys, proxies, logs, CSV results)
/data/**
!/data/.gitkeep

# Environment variables & secrets
.env
.env.*
*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
pip-wheel-metadata/
*.manifest

# Virtual environments
.venv/
venv/
ENV/
env/

# PyInstaller / build artifacts
build/
dist/
*.spec.bak
*.exe
SERPBot.exe

# Playwright browser cache (if installed locally in project)
.playwright/

# Test / lint / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE & editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Cursor local state
.cursor/

# Logs & crash dumps (if created outside data/)
*.log
crash_report.json
crash_page.html
